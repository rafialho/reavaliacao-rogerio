# Chave da API da Anthropic (obrigatória)
ANTHROPIC_API_KEY=sua_chave_aqui

# Modelo Claude a ser usado (opcional, padrão: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Porta do servidor (opcional, padrão: 3000)
PORT=3000

# Caminho do banco de dados SQLite (opcional, padrão: sessions.db)
DB_PATH=sessions.db
